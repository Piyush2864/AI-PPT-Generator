
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PresentationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PresentationTheme {
  MINIMAL
  CORPORATE
  CREATIVE
  DARK
  ACADEMIC
}

enum PresentationTone {
  FORMAL
  CASUAL
  INFORMATIVE
  PERSUASIVE
}

enum PresentationStyle {
  MINIMAL
  PROFESSIONAL
  CREATIVE
  BOLD
}

enum JobEventType {
  CREATED
  STARTED
  RETRY
  FAILED
  COMPLETED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  presentations Presentation[]
  refreshTokens RefreshToken[]

  @@map("users")
}


model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revoked   Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Presentation {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  topic       String
  audience    String
  language    String             @default("English")
  slideCount  Int                @map("slide_count")
  theme       PresentationTheme  @default(MINIMAL)
  tone        PresentationTone   @default(INFORMATIVE)
  style       PresentationStyle  @default(PROFESSIONAL)
  customInstructions String?     @map("custom_instructions") @db.Text

  status        PresentationStatus @default(PENDING)
  failureReason String?            @map("failure_reason")

  jobId String? @map("job_id")

  pdfUrl      String? @map("pdf_url")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slides  Slide[]
  jobLogs JobLog[]

  @@index([userId])
  @@index([status])
  @@map("presentations")
}

model Slide {
  id             String   @id @default(uuid())
  presentationId String   @map("presentation_id")
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  order   Int
  title   String
  content String   @db.Text
  notes   String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([presentationId])
  @@unique([presentationId, order])
  @@map("slides")
}


model JobLog {
  id             String       @id @default(uuid())
  presentationId String       @map("presentation_id")
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  eventType  JobEventType @map("event_type")
  attempt    Int          @default(1)
  message    String?      @db.Text
  durationMs Int?         @map("duration_ms")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([presentationId])
  @@map("job_logs")
}
